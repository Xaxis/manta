---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  intro?: string;
}

const { id, eyebrow, title, intro } = Astro.props;
---

<section id={id} class="border-t border-zinc-800 py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-6">
    {eyebrow && (
      <p class="mb-3 text-xs uppercase tracking-[0.18em] text-orange-400/80">
        {eyebrow}
      </p>
    )}
    <h2 class="text-3xl md:text-4xl font-semibold text-zinc-100 max-w-3xl">
      {title}
    </h2>
    {intro && (
      <p class="mt-4 max-w-3xl text-base md:text-lg text-zinc-400 leading-relaxed">
        {intro}
      </p>
    )}
    <div class="mt-10">
      <slot />
    </div>
  </div>
</section>

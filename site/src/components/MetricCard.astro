---
interface Props {
  label: string;
  value: string;
  unit?: string;
  note?: string;
  tone?: "neutral" | "warn" | "good";
}

const { label, value, unit, note, tone = "neutral" } = Astro.props;

const valueColor =
  tone === "warn" ? "text-orange-300" : tone === "good" ? "text-emerald-300" : "text-zinc-100";
---

<div class="rounded-lg border border-zinc-800 bg-zinc-900/30 p-5">
  <p class="text-xs uppercase tracking-wider text-zinc-500">{label}</p>
  <p class={`mt-2 font-semibold ${valueColor}`}>
    <span class="text-2xl mono">{value}</span>
    {unit && <span class="ml-1 text-base text-zinc-400">{unit}</span>}
  </p>
  {note && <p class="mt-2 text-xs text-zinc-500 leading-relaxed">{note}</p>}
</div>
